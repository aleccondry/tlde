# Provider selection — set to one of: github, openrouter, anthropic, openai, azure, ollama
TLDE_PROVIDER=github

# Model override — leave empty to use agent's default model
TLDE_MODEL=

# --- GitHub Copilot (default) ---
# Requires a GitHub Copilot subscription.
# Run: copilot auth login

# --- OpenRouter (https://openrouter.ai) ---
OPENROUTER_API_KEY=

# --- Anthropic (https://console.anthropic.com) ---
ANTHROPIC_API_KEY=

# --- OpenAI (https://platform.openai.com) ---
OPENAI_API_KEY=

# --- Azure OpenAI / AI Foundry ---
AZURE_OPENAI_KEY=
AZURE_OPENAI_ENDPOINT=